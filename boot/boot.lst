    17 0000012A 8EE8                <1>     mov gs, ax
    18                              <1> 
    19 0000012C BD00000900          <1>     mov ebp, 0x90000 ; 6. update the stack right at the top of the free space
    20 00000131 89EC                <1>     mov esp, ebp
