    20                                  %include "boot/gdt.asm"
     1                              <1> gdt_start: ; don't remove the labels, they're needed to compute sizes and jumps
     2                              <1>     ; the GDT starts with a null 8-byte
     3 000000D0 00000000            <1>     dd 0x0 ; 4 byte double word
     4 000000D4 00000000            <1>     dd 0x0 ; 4 byte
     5                              <1> 
     6                              <1> ; GDT for code segment. base = 0x00000000, length = 0xfffff
     7                              <1> ; for flags, refer to os-dev.pdf document, page 36
     8                              <1> gdt_code: 
     9 000000D8 FFFF                <1>     dw 0xffff    ; segment length, bits 0-15
    10 000000DA 0000                <1>     dw 0x0       ; segment base, bits 0-15
    11 000000DC 00                  <1>     db 0x0       ; segment base, bits 16-23
    12 000000DD 9A                  <1>     db 10011010b ; flags (8 bits)
    13 000000DE CF                  <1>     db 11001111b ; flags (4 bits) + segment length, bits 16-19
    14 000000DF 00                  <1>     db 0x0       ; segment base, bits 24-31
    15                              <1> 
    16                              <1> ; GDT for data segment. base and length identical to code segment
    17                              <1> ; some flags changed, again, refer to os-dev.pdf
    18                              <1> gdt_data:
    19 000000E0 FFFF                <1>     dw 0xffff
    20 000000E2 0000                <1>     dw 0x0
    21 000000E4 00                  <1>     db 0x0
    22 000000E5 92                  <1>     db 10010010b
    23 000000E6 CF                  <1>     db 11001111b
    24 000000E7 00                  <1>     db 0x0
    25                              <1> 
    26                              <1> gdt_end:
    27                              <1> 
    28                              <1> ; GDT descriptor
    29                              <1> gdt_descriptor:
    30 000000E8 1700                <1>     dw gdt_end - gdt_start - 1 ; size (16 bit), always one less of its true size
    31 000000EA [D0000000]          <1>     dd gdt_start ; address (32 bit)
    32                              <1> 
    33                              <1> ; define some constants for later use
    34                              <1> CODE_SEG equ gdt_code - gdt_start
    35                              <1> DATA_SEG equ gdt_data - gdt_start
